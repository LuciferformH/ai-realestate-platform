# ===========================================
# AI Real Estate Insights Platform
# Environment Variables Configuration
# ===========================================

# -------------------------------------------
# Database Configuration
# -------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_realestate
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ai_realestate
DB_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# -------------------------------------------
# Redis Configuration
# -------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=300

# -------------------------------------------
# Security
# -------------------------------------------
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# -------------------------------------------
# API Keys
# -------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4

# -------------------------------------------
# Application Configuration
# -------------------------------------------
ENVIRONMENT=development
DEBUG=true
APP_NAME=AI Real Estate Insights
APP_VERSION=1.0.0

# -------------------------------------------
# CORS Configuration
# -------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
ALLOWED_HOSTS=*

# -------------------------------------------
# Frontend Configuration
# -------------------------------------------
VITE_API_URL=http://localhost:8000

# -------------------------------------------
# Email Configuration (Optional)
# -------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@ai-realestate.com

# -------------------------------------------
# File Storage (Optional - AWS S3)
# -------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# -------------------------------------------
# Logging
# -------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# -------------------------------------------
# Rate Limiting
# -------------------------------------------
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10
